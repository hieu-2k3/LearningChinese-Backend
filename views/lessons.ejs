<div class="header">
    <h2>Lessons Management</h2>
    <a href="#" class="btn">+ New Lesson</a>
</div>

<div class="hsk-tabs" style="margin-bottom: 2rem; display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 10px;">
    <% for(let i=1; i<=9; i++) { %>
        <a href="/admin/lessons?hsk=<%= i %>" class="btn <%= currentHsk == i ? '' : 'btn-outline' %>"
            style="<%= currentHsk == i ? '' : 'background: white; color: var(--primary); border: 1px solid var(--primary);' %>">
            HSK <%= i %>
        </a>
        <% } %>
</div>

<table>
    <thead>
        <tr>
            <th>Order</th>
            <th>Title</th>
            <th>Summary</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% lessons.sort((a,b)=> a.order - b.order).forEach(lesson => { %>
            <tr>
                <td>#<%= lesson.order %>
                </td>
                <td><strong>
                        <%= lesson.title %>
                    </strong></td>
                <td>
                    <%= lesson.description ? lesson.description.substring(0, 30) + '...' : 'No description' %>
                </td>
                <td>
                    <a href="#" style="color: var(--primary)">Edit Parts</a> |
                    <a href="#" style="color: #EF4444">Delete</a>
                </td>
            </tr>
            <% }) %>
    </tbody>
</table>

<div class="card" style="margin-top: 3rem;">
    <h3>Add New Lesson to HSK <%= currentHsk %>
    </h3>
    <form action="/admin/lessons/add" method="POST"
        style="margin-top: 1rem; display: grid; gap: 1rem; grid-template-columns: 1fr 1fr;">
        <input type="hidden" name="hskLevel" value="<%= currentHsk %>">
        <input type="text" name="title" placeholder="Lesson Title (e.g. Greetings 1)" required
            style="padding: 0.5rem; border: 1px solid #DDD; border-radius: 4px;">
        <input type="number" name="order" placeholder="Order in Roadmap (e.g. 1)" required
            style="padding: 0.5rem; border: 1px solid #DDD; border-radius: 4px;">
        <textarea name="description" placeholder="Short description of the lesson"
            style="grid-column: span 2; padding: 0.5rem; border: 1px solid #DDD; border-radius: 4px;"></textarea>
        <button type="submit" class="btn" style="grid-column: span 2;">Create Standard Lesson</button>
    </form>
</div>